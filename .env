# ============================================================
# Aqro  Frontend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Variables must be prefixed with VITE_ to be exposed to the browser.
# NEVER commit .env to version control.
# ============================================================

# Express MongoDB API Configuration
# Local development - Express backend running on port 5000
VITE_API_BASE_URL=http://localhost:5000/api

# Production API URL (set when deploying backend)
# Example: VITE_API_BASE_URL=https://api.yourdomain.com/api

# Google Maps JavaScript API Key (optional)
# Enable: Maps JavaScript API + Visualization Library in GCP Console
# Restrict: HTTP referrers (your domain) for security
VITE_GOOGLE_MAPS_API_KEY=api key

